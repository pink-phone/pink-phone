# À copier en .env SUR LE SERVEUR (dans le dossier de déploiement). Ne pas committer.

# Secret de signature des JWT (générer une valeur longue et aléatoire).
JWT_SECRET=change-me-please-very-long-random

# Mot de passe Postgres (le service db et l'API l'utilisent).
POSTGRES_PASSWORD=change-me-too

# Port exposé sur le server pour le front (cible du reverse-proxy a reverse proxy).
WEB_PORT=8095

# Tag d'image à déployer. La CI le fixe à la version publiée lors du déploiement ;
# laisser "latest" pour un déploiement manuel.
IMAGE_TAG=latest

# Web Push (notifications). Générer : npx web-push generate-vapid-keys
# Laisser vide pour désactiver le push (les préférences restent stockées).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Auth email/mot de passe (true par défaut ; false => SSO uniquement)
PASSWORD_AUTH_ENABLED=true

# OIDC / SSO (ex: Authentik). Vides => SSO désactivé.
# L'app web servant /api en same-origin, le callback est sur le domaine public.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://jardin.example.com/api/auth/oidc/callback
OIDC_POST_LOGIN_REDIRECT=https://jardin.example.com/
