# Copier en .env et adapter.
DATABASE_URL=postgres://pink:pink@localhost:5432/pinkphone
# Secret de signature JWT. Doit faire >= 32 caractères (l'API refuse de démarrer
# en dehors de localhost avec un secret plus court). Générer :  openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Dossier de stockage des médias (HORS de tout dossier public)
MEDIA_DIR=./media-store
# Chiffrement des médias au repos (AES-256-GCM). Vide => stockés EN CLAIR sur
# disque. Fortement recommandé en production. Générer :  openssl rand -base64 32
# ⚠️ Ne JAMAIS changer cette clé une fois posée (médias chiffrés illisibles).
MEDIA_KEY=
# Adresse d'écoute
BIND_ADDR=127.0.0.1:8080
# Origines autorisées (CORS) — le front Vite
CORS_ORIGIN=http://localhost:5173

# Web Push (VAPID). Générer une paire avec :  npx web-push generate-vapid-keys
# Laisser vide pour désactiver l'envoi push (les préférences restent stockées).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Auth email/mot de passe (true par défaut ; false => connexion OIDC uniquement)
PASSWORD_AUTH_ENABLED=true

# OIDC / SSO (ex: Authentik). Tous vides => SSO désactivé.
# Enregistrer une application OAuth2/OIDC côté fournisseur avec l'URI de callback.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8080/api/auth/oidc/callback
OIDC_POST_LOGIN_REDIRECT=http://localhost:5173
